# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.
# These are placeholder names — rename them to match the services your agent uses.

# Your automation / workflow platform API
PLATFORM_BASE_URL=https://your-platform.example.com/api
PLATFORM_API_KEY=replace-me

# A data source (spreadsheet, database, warehouse, etc.)
DATA_SOURCE_API_KEY=replace-me

# Any additional third-party service the agent needs to reach
SERVICE_API_KEY=replace-me
